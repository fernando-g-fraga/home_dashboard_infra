# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=home_dashboard

# Backend (DATABASE_URL is built in docker-compose.yml from the Postgres vars above)
API_KEY=changeme
REDIS_URL=
TZ=UTC
LOG_LEVEL=INFO

# Frontend (embedded into the JS bundle at build time)
VITE_API_KEY=changeme

# Override the backend URL the nginx proxy forwards /api to (optional)
# API_BACKEND_URL=http://api:8000
